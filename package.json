{
  "name": "nova-systems-lab-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Official platform for Nova Systems Lab.",
  "license": "MIT",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
